<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/ivPerfilGrande"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:scaleType="centerCrop"
        android:background="#EEEEEE"
        android:src="@android:drawable/ic_menu_gallery" />

    <TextView
        android:id="@+id/tvDniPerfil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="DNI"
        android:textSize="18sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etNuevaFoto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="URL de la nueva foto"
        android:inputType="textUri" />

    <Button
        android:id="@+id/btnActualizarFoto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Actualizar Foto" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="20dp"
        android:background="#DDDDDD" />

    <EditText
        android:id="@+id/etNuevaPass"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nueva contraseña"
        android:inputType="textPassword" />

    <Button
        android:id="@+id/btnActualizarPass"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Actualizar Contraseña" />

</LinearLayout>